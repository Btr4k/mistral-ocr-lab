# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Required. Get a key at https://console.mistral.ai/api-keys
# Read server-side only — never prefix with NEXT_PUBLIC_.
MISTRAL_API_KEY=

# OCR model id.
MISTRAL_OCR_MODEL=mistral-ocr-4-0

# Public base URL of the app (used for absolute links).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upload limits.
OCR_MAX_FILE_SIZE_MB=10
OCR_MAX_PAGES=15

# OCR request timeout in milliseconds.
OCR_TIMEOUT_MS=180000

# Max concurrent OCR jobs and per-minute rate limit per client.
OCR_MAX_CONCURRENT_JOBS=2
OCR_RATE_LIMIT_PER_MINUTE=3

# Server log verbosity: debug | info | warn | error
LOG_LEVEL=info
